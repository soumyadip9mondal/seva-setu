# Frontend Environment Variables
# Copy this file to `.env` inside `/client` and adjust values as needed.

# Clerk publishable key (from Clerk dashboard)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# Backend API base URL used by Axios service
# Local dev default for this project:
VITE_API_BASE_URL=http://localhost:5000/api

# Twilio WhatsApp Sandbox Details
VITE_TWILIO_WHATSAPP_NUMBER=your_twilio_whatsapp_number
VITE_TWILIO_SANDBOX_CODE=your_sandbox_code
