// Prisma schema for SevaSetu — Real-time Volunteer Coordination & Community Needs Intelligence
// Uses PostgreSQL with PostGIS (spatial columns managed via raw SQL migrations)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

// ── Enums ─────────────────────────────────────────────────────────────

enum UserRole {
  user
  coordinator
  volunteer
  field_worker
}

enum NeedType {
  medical
  food
  shelter
  accidental
  rescue
  education
  other
}

enum NeedStatus {
  open
  assigned
  in_progress
  completed
  archived
  pending
  accepted
  rejected
}

enum TaskStatus {
  assigned
  in_progress
  completed
}

enum VolunteerRequestStatus {
  pending
  approved
  rejected
}

// ── Models ────────────────────────────────────────────────────────────

model Organization {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  contactEmail String?  @map("contact_email")
  district     String?
  createdAt    DateTime @default(now()) @map("created_at")

  users User[]

  @@map("organizations")
}

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clerkId      String?  @unique @map("clerk_id")
  name         String
  email        String   @unique
  phoneNumber  String?  @unique @map("phone_number")
  passwordHash String   @map("password_hash")
  role         UserRole @default(user)
  orgId        String?  @map("org_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  organization Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  volunteer    Volunteer?
  reportedNeeds      Need[]              @relation("ReportedNeeds")
  assignedTasks      Task[]              @relation("AssignedTasks")
  volunteerRequests  VolunteerRequest[]  @relation("UserVolunteerRequests")
  reviewedRequests   VolunteerRequest[]  @relation("ReviewedByCoordinator")
  broadcastRequests  BroadcastRequest[]  @relation("BroadcastRequests")

  @@map("users")
}

model BotSession {
  phoneNumber String   @id @map("phone_number")
  step        String   @default("idle")
  stateData   Json?    @map("state_data")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("bot_sessions")
}

model Volunteer {
  userId         String  @id @map("user_id") @db.Uuid
  skills         String[] @default([])
  location       Unsupported("geometry")?
  isAvailable    Boolean  @default(true) @map("is_available")
  tasksCompleted Int      @default(0) @map("tasks_completed")
  completionRate Float    @default(0.0) @map("completion_rate")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("volunteers")
}

model Need {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title          String
  description    String?
  needType       NeedType   @map("need_type")
  location       Unsupported("geometry")?
  ward           String?
  district       String?
  contactNumber  String?    @map("contact_number")
  peopleAffected         Int        @default(0) @map("people_affected")
  urgencyScore           Float      @default(1.0) @map("urgency_score")
  isVerified             Boolean    @default(false) @map("is_verified")
  verificationConfidence Float?     @map("verification_confidence")
  imageUrl               String?    @map("image_url")
  status                 NeedStatus @default(pending)
  rejectionReason        String?    @map("rejection_reason")
  verificationResult     Json?      @map("verification_result")
  isDisasterZone         Boolean    @default(false) @map("is_disaster_zone")
  reportedBy             String?    @map("reported_by") @db.Uuid
  createdAt              DateTime   @default(now()) @map("created_at")
  updatedAt              DateTime   @default(now()) @updatedAt @map("updated_at")

  reporter User?  @relation("ReportedNeeds", fields: [reportedBy], references: [id], onDelete: SetNull)
  tasks    Task[]
  broadcastRequests BroadcastRequest[]

  @@map("needs")
}

model Task {
  id                  String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  needId              String     @map("need_id") @db.Uuid
  assignedVolunteerId String     @map("assigned_volunteer_id") @db.Uuid
  status              TaskStatus @default(assigned)
  assignedAt          DateTime   @default(now()) @map("assigned_at")
  checkedInAt         DateTime?  @map("checked_in_at")
  checkInLat          Float?     @map("check_in_lat")
  checkInLng          Float?     @map("check_in_lng")
  completedAt         DateTime?  @map("completed_at")
  completionImageUrl  String?    @map("completion_image_url")
  isCompletionVerified Boolean   @default(false) @map("is_completion_verified")
  verificationResult   Json?      @map("verification_result")
  notes               String?

  need              Need @relation(fields: [needId], references: [id], onDelete: Cascade)
  assignedVolunteer User @relation("AssignedTasks", fields: [assignedVolunteerId], references: [id], onDelete: Cascade)

  @@index([assignedVolunteerId])
  @@map("tasks")
}

model BroadcastRequest {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  needId      String   @map("need_id") @db.Uuid
  volunteerId String   @map("volunteer_id") @db.Uuid
  status      String   @default("pending") // pending, accepted, rejected, expired
  distanceKm  Float?   @map("distance_km")
  createdAt   DateTime @default(now()) @map("created_at")
  expiresAt   DateTime @map("expires_at")

  need      Need @relation(fields: [needId], references: [id], onDelete: Cascade)
  volunteer User @relation("BroadcastRequests", fields: [volunteerId], references: [id], onDelete: Cascade)

  @@unique([needId, volunteerId])
  @@index([volunteerId, status])
  @@index([needId, status])
  @@map("broadcast_requests")
}

model CoordinatorEmail {
  id      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email   String   @unique
  addedAt DateTime @default(now()) @map("added_at")

  @@map("coordinator_emails")
}

model VolunteerRequest {
  id              String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String                 @map("user_id") @db.Uuid
  fullName        String                 @map("full_name")
  contactDetails  String                 @map("contact_details")
  proofOfWork     String                 @map("proof_of_work")
  status          VolunteerRequestStatus @default(pending)
  reviewedBy      String?                @map("reviewed_by") @db.Uuid
  reviewNote      String?                @map("review_note")
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @default(now()) @updatedAt @map("updated_at")

  user      User  @relation("UserVolunteerRequests", fields: [userId], references: [id], onDelete: Cascade)
  reviewer  User? @relation("ReviewedByCoordinator", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@map("volunteer_requests")
}
